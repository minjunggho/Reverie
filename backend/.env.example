# Reverie backend environment (copy to .env — NEVER commit the real .env)

# --- Database ---------------------------------------------------------------
# Blank = local SQLite dev file. Production: postgresql+asyncpg://...
REVERIE_DATABASE_URL=

# --- LLM provider -----------------------------------------------------------
REVERIE_LLM_PROVIDER=fake            # fake | anthropic | openai
REVERIE_LLM_MODEL=claude-opus-4-8
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Discord bot (the Table) --------------------------------------------------
DISCORD_BOT_TOKEN=

# --- Discord Activity (E6: Grimoire + DM Studio) ------------------------------
# Application (client) id — the ONLY Discord value the frontend may see.
DISCORD_CLIENT_ID=
# OAuth client secret — SERVER ONLY. Never in any VITE_* variable.
DISCORD_CLIENT_SECRET=
# HMAC key for Activity session tokens. Long random string in production;
# blank = random per process (dev only; sessions die on restart).
REVERIE_ACTIVITY_SESSION_SECRET=
REVERIE_ACTIVITY_SESSION_TTL_MINUTES=120

REVERIE_LOG_LEVEL=INFO
