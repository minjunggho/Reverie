# Reverie environment — copy to .env and fill in. NEVER commit .env.

# --- Database ---
# Production (PostgreSQL, async driver):
#   REVERIE_DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/reverie
# If unset, defaults to a local SQLite file (dev only).
REVERIE_DATABASE_URL=

# --- LLM provider ---
# fake | anthropic | openai   (default: fake — no external calls, used by tests)
REVERIE_LLM_PROVIDER=fake
REVERIE_LLM_MODEL=claude-opus-4-8
# Only required when the corresponding provider is active:
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Discord (only needed to run the live bot) ---
DISCORD_BOT_TOKEN=

# --- Misc ---
REVERIE_LOG_LEVEL=INFO
REVERIE_LLM_MAX_RETRIES=2
